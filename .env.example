# Optional. If missing, the dashboard uses mock US yield data.
FRED_API_KEY=

# Optional placeholders for future integrations.
ECONOMIC_CALENDAR_API_KEY=

# Optional. Primary candle source for EUR/USD.
TWELVE_DATA_API_KEY=
TWELVE_DATA_SYMBOL=EUR/USD
TWELVE_DATA_DAILY_ALIGNMENT_HOUR_NY=17
TWELVE_DATA_DO_START_HOUR_NY=1

# Optional. Enables automatic NY-aligned first H4 candle Daily Open range.
OANDA_API_TOKEN=
OANDA_ENVIRONMENT=practice
OANDA_INSTRUMENT=EUR_USD
OANDA_DAILY_ALIGNMENT_HOUR_NY=17
