# Required. FRED API Key is used to fetch Treasury yields, Net Liquidity, and macroeconomic data.
# Scoring will degrade gracefully if missing, but FRED categories will be unavailable.
FRED_API_KEY=

# Optional. Primary candle source for EUR/USD. Highly recommended for Weekly and Monthly price structure analysis.
TWELVE_DATA_API_KEY=
TWELVE_DATA_SYMBOL=EUR/USD
